# ═══════════════════════════════════════════════════════
#  LeadHunter — Environment Variables Template
#  Copy this file to .env and fill in the values.
#  !! Never commit .env to source control !!
# ═══════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=leadhunter
POSTGRES_USER=leadhunter
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

# ── Backend (FastAPI) ───────────────────────────────────
APP_NAME=LeadHunter API
API_V1_PREFIX=/api/v1
SECRET_KEY=change_me_super_secret_key_32_chars_min
CORS_ORIGINS=["http://localhost:3000"]
BACKEND_PORT=8000

# ── Frontend (Next.js) ──────────────────────────────────
# This is baked into the JS bundle at BUILD time.
# If deploying behind a reverse proxy, set this to the public API URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
FRONTEND_PORT=3000

# ── Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
